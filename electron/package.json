{
  "name": "anotes-electron",
  "version": "3.0.0",
  "description": "A Notes App V3 — Desktop",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.anotes.v3",
    "productName": "A Notes App V3",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "titlebar.js"
    ],
    "extraFiles": [
      {
        "from": "../frontend/dist",
        "to": "frontend"
      }
    ],
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  }
}