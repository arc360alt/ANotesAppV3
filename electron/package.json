{
  "name": "anotes-electron",
  "version": "3.0.0",
  "description": "A Notes App V3 — Desktop",
  "main": "main.js",
  "author": "your-name",
  "repository": {
    "type": "git",
    "url": "https://github.com/arc360alt/ANotesAppV3.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.anotes.v3",
    "productName": "A Notes App V3",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "titlebar.js"
    ],
    "extraFiles": [
        {
          "from": "frontend",
          "to": "frontend"
        }
      ],
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  }
}